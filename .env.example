# ── Required ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
GROQ_API_KEY=your_groq_api_key_here
PUBLIC_URL=https://your-server-url.com

# Postgres connection string.
# Local dev (with docker-compose up -d):
DATABASE_URL=postgresql://gitguard:gitguard@localhost:5432/gitguard
# On Render: attach a Postgres instance to this web service and Render
# will inject this automatically — you usually don't set it by hand there.

# ── Optional — Groq key fallback ────────────────────────────────────────────
# Add extra Groq API keys to fall back to (e.g. across free-tier accounts)
# when the current one is rate-limited or fails. They're tried in order;
# an error is only shown to the user if ALL keys fail. Either style works:
# GROQ_API_KEYS=key1,key2,key3,key4
# GROQ_API_KEY_2=your_second_groq_api_key
# GROQ_API_KEY_3=your_third_groq_api_key
# GROQ_API_KEY_4=your_fourth_groq_api_key

# ── Optional — sensible defaults shown ──────────────────────────────────────
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=4096
# GROQ_TEMPERATURE=0.3
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# ROLLBACK_STRATEGY=revert
# MAX_CONTEXT_FILES=50
# MAX_FILE_SIZE_BYTES=50000
# EXCLUDED_PATTERNS=.git,node_modules,__pycache__,.venv,*.lock,*.min.js,*.min.css,build,dist,.png,.jpg,.jpeg,.gif,.ico,.woff,.woff2,.ttf,.eot,.mp4,.mp3,.pdf,.zip,.tar.gz
# TELEGRAM_WEBHOOK_SECRET=

# Postgres pool tuning (defaults are fine for a few hundred users / 1 instance)
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_COMMAND_TIMEOUT_SECONDS=10
# DB_CONNECT_TIMEOUT_SECONDS=10

# ── Reliability / Phase 4 ────────────────────────────────────────────────────
# LOG_FORMAT=text            # "json" for structured logs (recommended on Render)
# ADMIN_CHAT_ID=              # your Telegram chat_id — enables admin alerts
# ALERT_FAILURE_THRESHOLD=5
# ALERT_WINDOW_SECONDS=600
# ALERT_COOLDOWN_SECONDS=1800
