# ─────────────────────────────────────────────────────────────
# CommitGuardian v2 — Multi-user edition
# Only THREE secrets needed server-side.
# Everything else (GitHub token, repo, branch) is collected
# per-user through the Telegram /start onboarding wizard.
# ─────────────────────────────────────────────────────────────

# 1. Telegram Bot token — from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional but recommended: secret token for Telegram webhook verification
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be 1-256 chars, only ASCII letters, digits, underscores, hyphens
TELEGRAM_WEBHOOK_SECRET=

# 2. Groq API key — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.3

# 3. Your public server URL (Render gives you this after deploy)
#    Example: https://commit-guardian.onrender.com
PUBLIC_URL=https://YOUR-RENDER-URL.onrender.com

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=10000

# Rollback strategy: revert (safe) or force_push (rewrites history)
ROLLBACK_STRATEGY=revert

# Optional analysis tuning
MAX_CONTEXT_FILES=50
MAX_FILE_SIZE_BYTES=50000
